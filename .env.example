# ─── ربات تلگرام ───
# از @BotFather بگیر
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─── OpenRouter (مغز AI) ───
# از https://openrouter.ai/keys یک کلید جدید بساز
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=google/gemini-2.5-pro
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── دیتابیس ───
# روی Railway این متغیر خودکار ساخته می‌شود (DATABASE_URL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_business_os

# ─── تنظیمات عمومی ───
# آیدی عددی تلگرام مالک سیستم (Super Admin) — از @userinfobot بگیر
SUPER_ADMIN_IDS=123456789

# واحد پول: toman یا rial
CURRENCY=toman

# مدت تریال به روز
TRIAL_DAYS=3
